    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst officeResponse = items.find(i => i.json.success);\nconst incidentData = items.find(i => i.json.incidentId);\nconst slackResponse = items.find(i => i.json.ok);\n\nreturn [\n  {\n    json: {\n      incidentId: incidentData?.json?.incidentId,\n      severity: incidentData?.json?.severity,\n      numericSeverity: incidentData?.json?.numericSeverity,\n      title: incidentData?.json?.title,\n      description: incidentData?.json?.description,\n      ownerEmail: incidentData?.json?.ownerEmail,\n      createdAt: incidentData?.json?.createdAt,\n      dedupeKey: incidentData?.json?.dedupeKey,\n      alreadyProcessed: incidentData?.json?.alreadyProcessed,\n      metadata: incidentData?.json?.metadata,\n\n      // ✅ Office 365 response renamed properly\n      office365: {\n        status: officeResponse?.json?.success || false,\n        response: officeResponse?.json?.message || \"Processed\"\n      },\n\n      // Slack response\n      slack: {\n        ok: slackResponse?.json?.ok || false,\n        channel: slackResponse?.json?.channel,\n        ts: slackResponse?.json?.ts\n      }\n    }\n  }\n];"
      },
