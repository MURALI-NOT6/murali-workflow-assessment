    {
      "parameters": {
        "jsCode": "// Get webhook body\nconst payload = $json.body;\n\n// ------------------------\n// 1️⃣ Required Field Validation\n// ------------------------\nconst requiredFields = [\"incidentId\", \"severity\", \"title\", \"createdAt\"];\n\nfor (const field of requiredFields) {\n  if (!payload[field]) {\n    throw new Error(`Missing required field: ${field}`);\n  }\n}\n\n// ------------------------\n// 2️⃣ Severity Mapping\n// ------------------------\nconst severityMap = {\n  P1: 1,\n  P2: 2,\n  P3: 3,\n  P4: 4,\n};\n\nconst numericSeverity = severityMap[payload.severity];\n\nif (!numericSeverity) {\n  throw new Error(\"Invalid severity value. Allowed: P1-P4\");\n}\n\n// ------------------------\n// 3️⃣ Truncate Description\n// ------------------------\nconst description = (payload.description || \"\").substring(0, 240);\n\n// ------------------------\n// 4️⃣ Generate Dedupe Key\n// Formula: incidentId_createdAt\n// ------------------------\nconst dedupeKey = `${payload.incidentId}_${payload.createdAt}`;\n\n// ------------------------\n// 5️⃣ Create Slack Message\n// ------------------------\nconst slackMessage =\n`${payload.title}\n\n${description ? description : \"\"}\n\nIncidentId: ${payload.incidentId}\nSeverity: ${payload.severity}\nCorrelationId: ${dedupeKey}\nCreatedAt: ${payload.createdAt}`;\n\n// ------------------------\n// 6️⃣ Create Email Content\n// ------------------------\nconst emailSubject = `[P${numericSeverity}] ${payload.title}`;\n\nconst emailBody = {\n  title: payload.title,\n  description: description ? description : \"\",\n  incidentId: payload.incidentId,\n  severity: payload.severity,\n  correlationId: dedupeKey,\n  createdAt: payload.createdAt\n};\n\n// ------------------------\n// Return Clean Normalized Object\n// ------------------------\nreturn [\n  {\n    json: {\n      incidentId: payload.incidentId,\n      severity: payload.severity,\n      numericSeverity,\n      title: payload.title,\n      description,\n      ownerEmail: payload.ownerEmail,\n      createdAt: payload.createdAt,\n      dedupeKey,\n      slackMessage,\n      emailSubject,\n      emailBody,\n      metadata:{\n        tags: payload.tags\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        544,
        1120
      ],
      "id": "7ec0de14-0002-4ff9-84b5-6ff212f1f500",
      "name": "Validate + Normalize1"
    },
    {
      "parameters": {
        "jsCode": "// Get workflow static storage\nconst staticData = $getWorkflowStaticData('global');\n\nif (!staticData.processed) {\n  staticData.processed = {};\n}\n\nconst dedupeKey = $json.dedupeKey;\n\n// If already processed\nif (staticData.processed[dedupeKey]) {\n  return [\n    {\n      json: {\n        ...$json,\n        alreadyProcessed: true\n      }\n    }\n  ];\n}\n\n// If not processed yet, mark as processed\nstaticData.processed[dedupeKey] = true;\n\nreturn [\n  {\n    json: {\n      ...$json,\n      alreadyProcessed: false\n    }\n  }\n];"
      },
